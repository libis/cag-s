{
    "name": "daniel-km/omeka-s-module-log",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Monitor all logging messages and background jobs directly in the admin board or in the cloud and make them translatable and easily checkable.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "monitor",
        "log",
        "psr-3",
        "logging",
        "job",
        "admin"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Log",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Log/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "autoload": {
        "psr-4": {
            "Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LogTest\\": "tests/LogTest/"
        }
    },
    "extra": {
        "installer-name": "Log",
        "configurable": true
    }
}
