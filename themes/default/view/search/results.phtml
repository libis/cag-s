<?php

/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SiteRepresentation|null $site
 * @var \AdvancedSearch\Api\Representation\SearchConfigRepresentation $searchConfig
 * @var \AdvancedSearch\Query $query
 * @var \AdvancedSearch\Response $response
 * @var string|null $resourceType The resource type may be "resources" or a specific one.
 * @var \Omeka\Api\Representation\ItemSetRepresentation|null $itemSet
 *
 * From themes:
 * @var string $gridListMode
 * @var array $properties
 */

// A check is done: when page is not first, the resources may be empty even with results.
$resources = $response->getResources($resourceType);
if (!$resources) return;

$plugins = $this->getHelperPluginManager();
$escape = $plugins->get('escapeHtml');
$assetUrl = $plugins->get('assetUrl');
$translate = $plugins->get('translate');
$hyperlink = $plugins->get('hyperlink');
$easyMeta = $plugins->get('easyMeta');
$thumbnail = $plugins->get('thumbnail');
$escapeAttr = $plugins->get('escapeHtmlAttr');
$escapeValueOrGetHtml = $plugins->get('escapeValueOrGetHtml');

$selectionButton = $site && $plugins->has('selectionButton') && $this->siteSetting('selection_append_items_browse_individual') ? $plugins->get('selectionButton') : null;
$contactUsSelector = $site && $plugins->has('contactUsSelector') && $this->siteSetting('contactus_append_items_browse_individual') ? $plugins->get('contactUsSelector') : null;

// Can be simplified in a public theme.
$setting = $plugins->get(isset($site) ? 'siteSetting' : 'setting');

$siteSlug = isset($site) ? $site->slug() : null;

$filterLocale = (bool) $setting('filter_locale_values');
$lang = $plugins->get('lang')();
$langValue = $filterLocale ? [$lang, ''] : null;

$untitled = $translate('[Untitled]');

$headingTerm = $setting('browse_heading_property_term');
$bodyTerm = $setting('browse_body_property_term');

$gridListMode ??= $searchConfig->subSetting('results', 'grid_list_mode', 'auto');

// A list does not have html-code in a consistant user interface.
$allowHtml = (bool) $searchConfig->subSetting('results', 'allow_html');

$thumbnailMode = $searchConfig->subSetting('results', 'thumbnail_mode', 'default');
$noThumbnail = $thumbnailMode === 'none';
$allThumbnail = $thumbnailMode === 'all';
$defaultThumbnail = $allThumbnail
  ? sprintf('<img loading="lazy" src="%1$s" title="%2$s"/>', $assetUrl('thumbnails/default.png', 'Omeka', true), $translate('No media'))
  : '';

$thumbnailType = $searchConfig->subSetting('results', 'thumbnail_type', 'medium');
$pagename = $searchConfig->name();
// Allow block to override properties from search config.
$properties = !empty($properties) ? $properties : $searchConfig->subSetting('results', 'properties', []);
$showProperties = !empty($properties);
$showLocale = (bool) $setting('show_locale_label');
?>

<div class="grid__12 <?php echo ($pagename != 'Verhalen' ? 'grid__8@med' : ''); ?>">
  <div class=" <?php echo ($pagename != 'Tijdschriften' ? 'grid--2-col@med' : 'ledenbox grid--3-col@med'); ?> spacer--xsm  grrid">
    <?php /** @var \Omeka\Api\Representation\AbstractResourceEntityRepresentation $resource */
    foreach ($resources as $resource):
      $resourceUrl = isset($site) ? $resource->siteUrl($siteSlug) : $resource->adminUrl();
      $resourceType = $resource->getControllerName();
      $heading = $headingTerm ? $resource->value($headingTerm, ['default' => $untitled, 'lang' => $langValue]) : $resource->displayTitle($untitled, $langValue);
      $body = $bodyTerm ? $resource->value($bodyTerm, ['lang' => $langValue, 'default' => '']) : $resource->displayDescription(null, $langValue);
      $resourceThumbnail = $noThumbnail ? null : $thumbnail($resource, $thumbnailType);
      $type = $resource->resourceTemplate();
      if ($type):
        $type = $type->label();
      else:
        $type = "Object";
      endif;

      if ($type == 'Verhaal' || $type == 'Project' || $type == 'Agendapunt' || $type == 'Nieuws'):
        if ($resource->value('dcterms:relation')):
          $url = '/page/' . $resource->value('dcterms:relation');
        else:
          $url = $resource->url();
        endif;
      elseif ($type == 'Ledenblad'):
        $url = '/item/' . $resource->id() . "?ref=search";
      else:
        $url = $resource->url() . "?ref=search";
      endif;
    ?>
      <?php

      //var_dump($_GET["filter"]);
      if ($type == 'Ledenblad' && isset($_GET["filter"])):
        $q = "";
        foreach ($_GET["filter"] as $key => $value):
          if ($value["join"] != "not"):
            $q = $q . " " . htmlspecialchars(strip_tags($value["value"]));
          endif;
        endforeach;
        $url = $url . "#?searchText=" . trim($q);
      endif;
      ?>

      <div class="grid__item">
        <div class="card card--clickable card--link card--variant2">

          <a href="<?php echo $url; ?>" style="display:block;">
            <?php echo sprintf('<%s class="%s">', "div", $resource->resourceName()); ?>
            <?php $media = $resource->primaryMedia(); ?>
            <?php if ($media): ?>
              <?php
              $file_url = str_replace('http:', '', $media->thumbnailUrl('medium'));
              //$file_url = $media->originalUrl();
              if ($file_url == "/application/asset/thumbnails/default.png?v=3.2.3") {
                $media = $resource->thumbnail();
                if ($media) {
                  if ($media->getControllerName() == "asset"):
                    $file_url = $media->assetUrl('medium');
                  endif;
                }
              }
              ?>
              <div class="card__img card__img_3"
                style="background:url(<?php echo $file_url; ?>) no-repeat center 20%;background-size: cover;"></div>
            <?php endif; ?>


            <div class="card__body panel panel--light">
              <?php
              if ($type == 'Ledenblad'):
                $title = $resource->displayTitle();
                $title = explode(", ", $title);
                $date = isset($title[1]) ? $title[1] : $title[0];
                $title = isset($title[2]) ? explode(":", $title[2]) : $title[0];
                $nr = $title[0];
                $title = isset($title[1]) ? $title[1] : $title[0];
                //check if title is correct
                $old_titles = $resource->value('dcterms:replaces', array('all' => true));
                foreach ($old_titles as $old_title):
                  preg_match('#\((.*?)\)#', $old_title . '', $match);
                  $dates = explode("-", $match[1]);
                  if ($date >= $dates[0] && $date <= $dates[1]):
                    $title = $old_title . '';
                  endif;
                endforeach;
                $title = trim($title) . ", " . $date . ", " . $nr;
              else:
                $title = $resource->displayTitle();
              endif;
              ?>
              <h2 class="heading--3 card__title"><a href="<?php echo $url; ?>"><?php echo $title; ?></a></h2>
              <?php if ($type == 'Beeld'): ?>
                <p class="datering"><?php echo $resource->value('dcterms:date'); ?></p>
              <?php endif; ?>

              <?php
              if ($type == 'Ledenblad' && isset($_GET["filter"])):
                $media = $resource->media();

                if (isset($media[1])):
                  $text = $helper->normalize_ocr_text($media[1]->render());
                endif;

                if ($text) {
                  foreach ($_GET["filter"] as $key => $value) {

                    if ($value["join"] != "not" && $value["value"]) {

                      $search_text = $value["value"]; // raw user input

                      $snippet = $helper->make_flexible_snippet($text, $search_text);

                      if ($snippet) {
                        echo "<div class='snippet'>{$snippet}</div>";
                        break;
                      }
                    }
                  }
                }
              endif;
              ?>

              <?php if ($type == 'Film' && $resource->value('dcterms:source')): ?>
                <?php
                $codes = array(
                  'GB' => 'Verenigd Koninkrijk',
                  'UK' => 'Verenigd Koninkrijk',
                  'NL' => 'Nederland',
                  'IT' => 'Italië',
                  'SZ' => 'Zwitserland',
                  'FR' => 'Frankrijk',
                  'CN' => 'Canada',
                  'BE' => 'België',
                  'US' => 'Verenigde Staten',
                  'AU' => 'Oostenrijk',
                  'LU' => 'Luxemburg',
                  'DE' => 'Duitsland',
                  'GW' => 'Duitsland'
                );
                ?>
                <p class="datering">
                  <?php if ($resource->value('dcterms:date')): ?>
                    <?php echo $resource->value('dcterms:date'); ?>
                  <?php endif; ?>
                  <?php if ($resource->value('dcterms:source')): ?>
                    <?php echo isset($codes[$resource->value('dcterms:source')->asHtml()]) ? $codes[$resource->value('dcterms:source')->asHtml()] : ""; ?>
                  <?php endif; ?>
                  <?php if ($resource->value('dcterms:language')): ?>
                    <?php echo "(" . $resource->value('dcterms:language') . ")"; ?>
                  <?php endif; ?>
                </p>
              <?php endif; ?>
              <?php if ($type == 'Film' && !$resource->value('dcterms:date') && !$resource->value('dcterms:source') && $resource->value('dcterms:language')): ?>
                <p class="datering">
                  <?php if ($resource->value('dcterms:language')): ?>
                    <?php echo "(" . $resource->value('dcterms:language') . ")"; ?>
                  <?php endif; ?>
                </p>
              <?php endif; ?>
              <?php if ($resource->value('dcterms:date') && ($type == 'Nieuws' || $type == 'Agendapunt')): ?>
                <?php
                $date = $resource->value('dcterms:date');
                $date = DateTime::createFromFormat('Ymd', $date);
                $output = $date->format('d-m-Y');
                ?>
                <p class="datering"><?php echo $output; ?></p>
              <?php endif; ?>
              <?php if ($description = $resource->displayDescription()): ?>
                <?php
                if (strlen(strip_tags($description)) > 200):
                  $description = substr(strip_tags($description), 0, 200);
                  $description = substr($description, 0, strrpos($description, ' ')) . ' ...';
                endif;
                ?>
                <p class="description">
                  <?php echo $description; ?>
                </p>
              <?php endif; ?>
              <?php if ($type == 'Film' || $type == 'Filmkopie'): ?>
                <div class="link link--ext card__link"><a href="<?php echo $url; ?>">Lees meer</a></div>
              <?php elseif ($type == 'Ledenblad'): ?>
                <div class="link link--ext card__link"><a href="<?php echo $url; ?>">Tijdschrift bekijken</a></div>
              <?php else: ?>
                <div class="link link--ext card__link"><a href="<?php echo $url; ?>"><?php echo $type; ?> bekijken</a></div>
              <?php endif; ?>
            </div>
          </a>
        </div>
      </div>
  </div>
<?php endforeach; ?>
</div>
</div>